# Copy to mobile/.env and adjust for your environment. Never commit .env.
#
# Base URL of the Spring Boot backend. EXPO_PUBLIC_* vars are inlined into the
# JS bundle at build time — never put secrets in them.
#
# Android emulator -> host machine's localhost:
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
#
# Alternative if 10.0.2.2 misbehaves: run `adb reverse tcp:8080 tcp:8080`,
# then use http://localhost:8080
#
# Non-local environments MUST use https:// (the app refuses plain http
# for non-local hosts; see plan.md Constitution Check, Principle II).
